{
	"name": "synthetic.software",
	"private": true,
	"version": "2.4.4",
	"type": "module",
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:full": "pnpm run generate && pnpm run build",
		"postbuild": "find build/_app -name '*.js' -delete && find build/_app -type d -empty -delete",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"generate": "tsx scripts/prebuild.ts",
		"generate:blogroll": "tsx scripts/generate-blogroll.ts",
		"generate:changelog": "tsx scripts/generate-changelog.ts",
		"analyze-tags": "tsx scripts/analyze-tags.ts",
		"suggest-tags": "tsx scripts/suggest-tags.ts",
		"lint-prose": "tsx scripts/lint-prose.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.5",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.70.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.3",
		"@types/node": "^22.20.1",
		"eslint": "^9.39.5",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^16.5.0",
		"harper.js": "^1.12.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"rehype-stringify": "^10.0.1",
		"rss-parser": "^3.13.0",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.3.3",
		"tsx": "^4.23.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.64.0",
		"unified": "^11.0.5",
		"uniorg": "^1.4.0",
		"uniorg-parse": "^3.2.2",
		"uniorg-rehype": "^2.2.0",
		"vite": "^7.3.6",
		"wrangler": "^4.112.0",
		"yaml": "^2.9.0"
	}
}
